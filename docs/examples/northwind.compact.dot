digraph DbSketch {
  graph [
    rankdir=LR,
    labelloc="t",
    label="Northwind schema - compact"
  ];

  node [
    shape=plain
  ];

  edge [
    fontsize=10
  ];

  "table_northwind_categories" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.categories</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_category_id" ALIGN="LEFT">category_id</TD></TR>
        <TR><TD PORT="col_category_name" ALIGN="LEFT">category_name</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_customers" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.customers</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_customer_id" ALIGN="LEFT">customer_id</TD></TR>
        <TR><TD PORT="col_company_name" ALIGN="LEFT">company_name</TD></TR>
        <TR><TD PORT="col_contact_name" ALIGN="LEFT">contact_name</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_employees" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.employees</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_employee_id" ALIGN="LEFT">employee_id</TD></TR>
        <TR><TD PORT="col_last_name" ALIGN="LEFT">last_name</TD></TR>
        <TR><TD PORT="col_first_name" ALIGN="LEFT">first_name</TD></TR>
        <TR><TD PORT="col_reports_to" ALIGN="LEFT">reports_to</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_orders" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.orders</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_order_id" ALIGN="LEFT">order_id</TD></TR>
        <TR><TD PORT="col_customer_id" ALIGN="LEFT">customer_id</TD></TR>
        <TR><TD PORT="col_employee_id" ALIGN="LEFT">employee_id</TD></TR>
        <TR><TD PORT="col_order_date" ALIGN="LEFT">order_date</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_order_details" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.order_details</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_order_id" ALIGN="LEFT">order_id</TD></TR>
        <TR><TD PORT="col_product_id" ALIGN="LEFT">product_id</TD></TR>
        <TR><TD PORT="col_unit_price" ALIGN="LEFT">unit_price</TD></TR>
        <TR><TD PORT="col_quantity" ALIGN="LEFT">quantity</TD></TR>
        <TR><TD PORT="col_discount" ALIGN="LEFT">discount</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_products" [
    label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
        <TR><TD BGCOLOR="#EEEEEE" ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD ALIGN="LEFT">northwind.products</TD></TR></TABLE></TD></TR>
        <TR><TD PORT="col_product_id" ALIGN="LEFT">product_id</TD></TR>
        <TR><TD PORT="col_product_name" ALIGN="LEFT">product_name</TD></TR>
        <TR><TD PORT="col_category_id" ALIGN="LEFT">category_id</TD></TR>
        <TR><TD PORT="col_unit_price" ALIGN="LEFT">unit_price</TD></TR>
      </TABLE>
    >
  ];

  "table_northwind_employees":"col_reports_to":e -> "table_northwind_employees":"col_employee_id":w;
  "table_northwind_orders":"col_customer_id":e -> "table_northwind_customers":"col_customer_id":w;
  "table_northwind_orders":"col_employee_id":e -> "table_northwind_employees":"col_employee_id":w;
  "table_northwind_order_details":"col_order_id":e -> "table_northwind_orders":"col_order_id":w;
  "table_northwind_order_details":"col_product_id":e -> "table_northwind_products":"col_product_id":w;
  "table_northwind_products":"col_category_id":e -> "table_northwind_categories":"col_category_id":w;
}
